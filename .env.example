# VibeCopy - Polymarket Copy Trading Bot Configuration

# REQUIRED: Target traders' Polygon wallet addresses (comma-separated)
# Can follow one or multiple accounts
TARGET_ADDRESSES=0xYOUR_TARGET_WALLET_ADDRESS_HERE

# REQUIRED for live mode: Your wallet private key (0x-prefixed hex)
# WARNING: Use a dedicated wallet with only the funds you're willing to risk
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Your Polymarket proxy wallet address (found on your Polymarket profile URL)
# This is your trading wallet - different from the signing key address
PROXY_WALLET=0xYOUR_PROXY_WALLET_HERE

# Signature type: 0 = EOA (direct wallet), 1 = Magic/email login, 2 = browser wallet
SIGNATURE_TYPE=1

# Mode: "simulate" (paper trading) or "live" (real orders)
MODE=simulate

# Copy 1/N of the target's bet size (e.g. 10 = if they bet $10, you bet $1)
COPY_DIVISOR=10.0

# Max % of balance per trade (cap, prevents over-exposure)
RISK_PCT=2

# Seconds between polling for new trades (min: 1.0)
POLL_INTERVAL=3.0

# Seconds between status summary prints
STATUS_INTERVAL=30.0

# Risk limits
MAX_DAILY_LOSS_USD=50.0
MAX_SLIPPAGE_PCT=5.0
